# Mapbox token for the map component
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# Contact Email
VITE_EMAIL=support@example.com

# Contact Phone
VITE_PHONE=1234567890

# Backend API base URL (e.g., http://localhost:8000/api/v1)
VITE_API_URL=http://localhost:8000/api/v1

# Backend server URL for WebSocket (e.g., http://localhost:8000)
VITE_BACKEND_URL=http://localhost:8000

# Admin panel URL for salon owners (e.g., http://localhost:5174)
VITE_ADMIN_URL=http://localhost:5174
